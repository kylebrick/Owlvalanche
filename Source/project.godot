[layer_names]

2d_render/layer_1="Player"
2d_render/layer_2="NPCs"
2d_render/layer_3="Boundaries"
2d_render/layer_4="Interactables"
2d_render/layer_5="Hazards"
2d_render/layer_6="FX"
2d_render/layer_7="Misc."

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0

; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Owlvalanche"
run/main_scene="uid://befjo26bldyc1"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/max_fps=60
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/image="uid://dv6j1d56cl38j"
config/icon="uid://dv6j1d56cl38j"
config/windows_native_icon="res://Icons/icon_owl.ico"

[display]

window/size/viewport_width=240
window/size/viewport_height=135
window/size/initial_position_type=5
window/size/borderless=true
window/size/always_on_top=true
window/size/sharp_corners=true
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="viewport"

[global_group]

Player="The owl player charracter - there should only be one of these."

